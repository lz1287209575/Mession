{
  "default": "cmake",
  "systems": [
    {
      "name": "cmake",
      "description": "Default CMake release build",
      "commands": [
        [
          "cmake",
          "-S",
          ".",
          "-B",
          "{build_dir}",
          "-DCMAKE_BUILD_TYPE=Release"
        ],
        [
          "cmake",
          "--build",
          "{build_dir}",
          "-j4"
        ]
      ]
    },
    {
      "name": "custom-ninja",
      "description": "Example custom pipeline using env injection",
      "cwd": "{project_root}",
      "env": {
        "MESSION_CUSTOM_OUT": "{build_dir}"
      },
      "commands": [
        "cmake -S . -B {build_dir} -G Ninja -DCMAKE_BUILD_TYPE=RelWithDebInfo",
        "cmake --build {build_dir} -j8"
      ]
    }
  ]
}
