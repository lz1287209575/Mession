{
  "default": "cmake",
  "systems": [
    {
      "name": "cmake",
      "description": "Default CMake release build",
      "commands": [
        [
          "cmake",
          "-S",
          ".",
          "-B",
          "{build_dir}",
          "-DCMAKE_BUILD_TYPE=Release"
        ],
        [
          "cmake",
          "--build",
          "{build_dir}",
          "-j4"
        ]
      ]
    }
  ]
}
